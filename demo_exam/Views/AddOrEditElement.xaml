<Window x:Class="lab2.Views.AddOrEditElement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2.Views"
        mc:Ignorable="d"
        Height="600" Width="800">
    <StackPanel 
        VerticalAlignment="Center" 
        HorizontalAlignment="Center"
    >
        <TextBlock 
            FontSize="20" 
            Name="BoxTitle"
            FontWeight="Bold" 
            HorizontalAlignment="Center"
        />
        <StackPanel 
            Margin="0 40 0 0"
            Orientation="Horizontal"
        >
            <StackPanel Margin="0 0 20 0">
                <TextBlock 
                    Text="Фото"
                    Margin="0 0 0 15"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <Image  
                    Name="ImageBox"
                    Width="300"
                    Height="300"
                />
                <Button 
                    Height="25"
                    Width="150"
                    Margin="0 15 0 0"
                    Content="Добавить фото"
                    Name="ImageButton"
                    Click="ImageButtonClick"
                />
            </StackPanel>
            <WrapPanel Width="310">
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20" 
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Артикль" 
                    />
                    <TextBox Name="ArticleTextBox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20" 
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Наименование" 
                    />
                    <TextBox Name="NameTextBox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Категория" 
                    />
                    <ComboBox Name="CategoryCombobox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Описание" 
                    />
                    <TextBox Name="DescriptionTextBox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5"
                        Text="Производитель" 
                    />
                    <ComboBox Name="ManufacturerCombobox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Поставщик" 
                    />
                    <ComboBox Name="SupplierCombobox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Цена" 
                    />
                    <TextBox Name="PriceTextBox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5"
                        Text="Единица измерения"
                    />
                    <ComboBox Name="UnitCombobox"/>
                </StackPanel>
                <StackPanel 
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Margin="0 0 0 5" 
                        Text="Количество на складе" 
                    />
                    <TextBox Name="WarehouseCountTextBox"/>
                </StackPanel>
                <StackPanel
                    Width="150"
                    Margin="0 0 5 20"
                >
                    <TextBlock 
                        Text="Скидка" 
                        Margin="0 0 0 5" 
                    />
                    <TextBox Name="DiscountTextBox"/>
                </StackPanel>
            </WrapPanel>
        </StackPanel>
        <StackPanel
            Margin="0 50 0 0"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
        >
            <Button 
                Width="150"
                Height="25"
                Name="ActionButton"
                Click="ActionButtonClick"
            />        
            <Button 
                Width="150"
                Height="25"
                Margin="20 0 0 0"
                Content="Отмена"
                Click="ButtonExit"
            />
        </StackPanel>
    </StackPanel>
</Window>

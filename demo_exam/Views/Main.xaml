<Window x:Class="lab2.Views.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2.Views"
        mc:Ignorable="d"
        Title="Приложение" Height="850" Width="1600">
    <DockPanel>
        <DockPanel
            Margin="30 15 30 15"
            DockPanel.Dock="Top"
        >
            <TextBlock 
                DockPanel.Dock="Right"
                VerticalAlignment="Center"
            >
                <Run Text="Добро пожаловать: "/>
                <Run Name="BoxUserName"/>
            </TextBlock>
            <Button 
                Width="100"
                Height="30"
                Content="Выход"
                Click="ButtonExit"
            />
            <StackPanel />
        </DockPanel>
        <StackPanel 
            Margin="30 15 0 15"
            Name="PanelFind"
            DockPanel.Dock="Top"
            Visibility="Collapsed"
            Orientation="Horizontal"
        >
            <Label Content="Поиск" />
            <TextBox 
                Name="BoxFind" 
                Width="150"
                TextChanged="BoxFindTextChanged"
            />
            <RadioButton 
                Margin="30 0 0 0"
                Content="По возрастанию"
                VerticalAlignment="Center"
                Checked="RadioButtonChecked"
            />
            <RadioButton 
                Margin="15 0 0 0"
                Content="По убыванию"
                VerticalAlignment="Center"
                Checked="RadioButtonChecked"
            />
            <ComboBox 
                Width="150"
                Margin="30 0 0 0"
                SelectedIndex="0"
                Name="ComboFilter"
                SelectionChanged="ComboFilterSelection" 
            />
        </StackPanel>
        <StackPanel
            Name="PanelCRUD"
            Margin="30 15 0 15"
            Visibility="Collapsed"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal"
        >
            <Button Content="Добавить"
                    Width="170"
                    Height="30"
                    Click="ButtonCreateElement"/>
            <Button Content="Удалить"
                    Width="170"
                    Height="30"
                    Margin="50 0 0 0"
                    Click="ButtonDeleteElement"/>
        </StackPanel>
        <ListBox 
            Name="BoxElements"
            Width="1540" 
            Height="700"
        />
    </DockPanel>
</Window>
<UserControl x:Class="lab2.Controllers.ItemElementController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:lab2.Controllers"
             mc:Ignorable="d" 
             d:DesignHeight="215" d:DesignWidth="1450">
    <Border BorderBrush="Black"
        BorderThickness="1">
        <Grid Margin="5 5 5 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Image  Name="BoxImage"
                        Width="300"
                        Height="300"
                />
            </StackPanel>
            <StackPanel Margin="10 10 0 0" 
                        Grid.Column="1"
                        Width="800">
                <TextBlock FontSize="20" FontWeight="Bold">
                    <Run Text="{Binding Name}" />
                    <Run Text=" - " />
                    <Run Text="{Binding Type.Type}"/>
                </TextBlock>
                <TextBlock FontSize="20">
                    <Run Text="Производитель: " />
                    <Run Text="{Binding Manufacturer.Name}"/>
                </TextBlock>
                <TextBlock FontSize="20">
                    <Run Text="Поставщик: " />
                    <Run Text="{Binding Supplier.Name}"/>
                </TextBlock>
                <TextBlock FontSize="20">
                    <Run Text="Единица аренды: " />
                    <Run Text="{Binding Unit.Name}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding Count}"
                         Name="BoxCount"
                         />
                </TextBlock>
                <TextBlock FontSize="20" TextWrapping="Wrap">
                    <Run Text="Описание оборудования: " />
                    <Run Text="{Binding Description}"/>
                </TextBlock>
            </StackPanel>
            <Grid Grid.Column="2" Margin="10 10 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <TextBlock FontSize="20" Grid.Row="0">
                    <Run Text="Цена аренды: "/>
                    <Run Text="{Binding Price}"
                         Name="BoxPrice"
                         />
                    <Run Name="BoxNewPrice" />
                    <Run Text="(Р)" />
                </TextBlock>
                <TextBlock Name="BoxDiscont"
                           FontSize="20" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Grid.Row="1">
                    <Run Text="{Binding Discount}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>

<Window x:Class="lab2.Views.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2.Views"
        mc:Ignorable="d"
        Title="Авторизация" Height="300" Width="300">
    <StackPanel
        HorizontalAlignment="Center" 
        VerticalAlignment="Center"
    >
        <TextBlock 
            Text="Авторизация" 
            FontSize="20" 
            FontWeight="Bold" 
            HorizontalAlignment="Center"
        />
        <StackPanel Margin="0 20">
            <TextBlock 
                Text="Логин" 
                Margin="0 0 0 5" 
            />
            <TextBox Name="BoxLogin"/>
        </StackPanel>
        <StackPanel Margin="0 0 0 20">
            <TextBlock 
                Text="Пароль" 
                Margin="0 0 0 5" 
            />
            <TextBox Name="BoxPassword"/>
        </StackPanel>
        <StackPanel 
            Margin="0 0 0 10"
            Orientation="Horizontal" 
        >
            <Button 
                Width="80" 
                Height="25" 
                Content="Войти" 
                Margin="0 0 15 0" 
                Click="ButtonLogin"
            />
            <Button 
                Width="150"
                Height="25" 
                Content="Войти как гость" 
                Click="ButtonLoginGuest"
            />
        </StackPanel>
    </StackPanel>
</Window>
